    {
      "name": "posts 文章接口",
      "item": [
        {
          "name": "新增文章",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"状态码是 201\", function () {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"返回 id 字段\", function () {\r",
                  "    const data = pm.response.json();\r",
                  "    pm.expect(data).to.have.property(\"id\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"title 创建成功\", function () {\r",
                  "    const data = pm.response.json();\r",
                  "    pm.expect(data.title).to.eql(pm.environment.get(\"new_post_title\"));\r",
                  "});\r",
                  "\r",
                  "pm.test(\"body 创建成功\", function () {\r",
                  "    const data = pm.response.json();\r",
                  "    pm.expect(data.body).to.eql(pm.environment.get(\"new_post_body\"));\r",
                  "});\r",
                  "\r",
                  "pm.test(\"保存 post_id 到环境变量\", function () {\r",
                  "    const data = pm.response.json();\r",
                  "    pm.environment.set(\"post_id\", data.id);\r",
                  "    pm.expect(pm.environment.get(\"post_id\")).to.not.be.empty;\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"title\": \"{{new_post_title}}\",\r\n  \"body\": \"{{new_post_body}}\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/posts",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "posts"
              ]
            }
          },
          "response": []
        },
